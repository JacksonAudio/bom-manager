{
  "rewrites": [{ "source": "/api/(.*)", "destination": "/api/$1" }, { "source": "/(.*)", "destination": "/index.html" }],
  "functions": {
    "api/parse-invoice.js": {
      "maxDuration": 60
    },
    "api/search-components.js": {
      "maxDuration": 120
    },
    "api/shopify-history.js": {
      "maxDuration": 120
    },
    "api/zoho-history.js": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/low-stock-alert",
      "schedule": "0 14 * * *"
    }
  ]
}
