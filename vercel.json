{
  "rewrites": [{ "source": "/api/(.*)", "destination": "/api/$1" }, { "source": "/(.*)", "destination": "/index.html" }],
  "functions": {
    "api/parse-invoice.js": {
      "maxDuration": 60
    },
    "api/search-components.js": {
      "maxDuration": 60
    },
    "api/shopify.js": {
      "maxDuration": 60
    },
    "api/zoho.js": {
      "maxDuration": 60
    },
    "api/shipstation.js": {
      "maxDuration": 60
    },
    "api/mouser-cart.js": {
      "maxDuration": 60
    },
    "api/backup.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/low-stock-alert",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/backup",
      "schedule": "0 6 * * *"
    }
  ]
}
